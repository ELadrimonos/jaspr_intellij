<idea-plugin>
    <id>com.github.eladrimonos.jasprintellij</id>
    <name>Jaspr | Dart Web Framework</name>
    <vendor>Adrián Primo Bernat</vendor>

    <description>
        <![CDATA[
<p>Adds <a href="https://jaspr.site">Jaspr</a> framework support to JetBrains IDEs.</p>

<p>Jaspr is a web framework for Dart that lets you build type-safe, reactive web applications.
This plugin integrates the Jaspr toolchain directly into your IDE.</p>

<p><i>Requires the Dart plugin and jaspr_cli.</i></p>

<h3>Run Configuration</h3>
<p>Run <code>jaspr daemon</code> directly from the IDE with graceful shutdown and Chrome lifecycle management.</p>

<h3>Component Scopes</h3>
<p>Inline code vision hints show whether a component renders on the server or the client, powered by the <code>jaspr tooling-daemon</code>.</p>

<h3>HTML to Jaspr Conversion</h3>
<p>Right-click any <code>.html</code> file and select <b>Convert to Jaspr</b> to generate the equivalent Dart component.</p>

<h3>New Project Wizard</h3>
<p>Create a new Jaspr project from scratch using the IDE's project wizard with full CLI integration.</p>

<h3>Live Templates</h3>
<p>Built-in templates for common patterns: <code>stlessc</code>, <code>stfulc</code>, <code>jhtml</code>, <code>jtext</code>, and more.</p>

<h3>Advanced Tooling</h3>
<p>Run <code>jaspr clean</code> and <code>jaspr doctor</code> from the Tools menu. Includes version mismatch notifications and console output formatting.</p>
    ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>Dart</depends>

    <resource-bundle>messages.JasprBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">

        <config.codeVisionGroupSettingProvider
                implementation="com.github.eladrimonos.jasprintellij.editor.codevision.JasprCodeVisionGroupSettingProvider"/>

        <codeInsight.daemonBoundCodeVisionProvider order="first"
                                                   implementation="com.github.eladrimonos.jasprintellij.editor.codevision.JasprServerScopeProvider"/>
        <codeInsight.daemonBoundCodeVisionProvider
                implementation="com.github.eladrimonos.jasprintellij.editor.codevision.JasprClientScopeProvider"/>
        <codeInsight.daemonBoundCodeVisionProvider order="last"
                                                   implementation="com.github.eladrimonos.jasprintellij.editor.codevision.JasprHintScopeProvider"/>

        <console.folding
                implementation="com.github.eladrimonos.jasprintellij.execution.JasprBuilderConsoleFolding"/>

        <postStartupActivity
                implementation="com.github.eladrimonos.jasprintellij.startup.JasprProjectActivity"/>

        <configurationType
                implementation="com.github.eladrimonos.jasprintellij.execution.runconfig.JasprRunConfigurationType"/>
        <programRunner implementation="com.github.eladrimonos.jasprintellij.execution.runconfig.JasprProgramRunner"/>

        <notificationGroup
                id="JasprIntelliJ"
                displayType="BALLOON"
                isLogByDefault="false" bundle="messages.JasprBundle"/>

        <defaultLiveTemplates file="/liveTemplates/jaspr.xml"/>
        <liveTemplateContext
                contextId="JASPR_TOPLEVEL"
                implementation="com.github.eladrimonos.jasprintellij.template.JasprTopLevelTemplateContextType"/>
        <liveTemplateContext
                contextId="JASPR_STATEMENT"
                implementation="com.github.eladrimonos.jasprintellij.template.JasprStatementTemplateContextType"/>
        <liveTemplateContext
                contextId="JASPR_ANYWHERE"
                implementation="com.github.eladrimonos.jasprintellij.template.JasprAnywhereTemplateContextType"/>

        <internalFileTemplate name="StatelessComponent.dart"/>
        <internalFileTemplate name="StatefulComponent.dart"/>
        <internalFileTemplate name="InheritedComponent.dart"/>

        <localInspection
                language="Dart"
                bundle="messages.JasprBundle"
                key="jaspr.inspection.multiple.annotations.name"
                groupKey="jaspr.inspection.group.name"
                enabledByDefault="true"
                level="ERROR"
                shortName="JasprMultipleAnnotations"
                implementationClass="com.github.eladrimonos.jasprintellij.inspection.JasprMultipleAnnotationsInspection"/>

        <newProjectWizard.generator
                implementation="com.github.eladrimonos.jasprintellij.template.project.JasprNewProjectWizard"/>

        <directoryProjectGenerator
                implementation="com.github.eladrimonos.jasprintellij.template.project.JasprDirectoryProjectGenerator"/>

    </extensions>

    <actions>
        <group id="JasprToolsGroup" class="com.github.eladrimonos.jasprintellij.actions.JasprActionGroup" text="Jaspr"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="Jaspr.Build" class="com.github.eladrimonos.jasprintellij.actions.JasprBuildAction"
                    text="Jaspr Build" description="Run 'jaspr build'"/>
            <action id="Jaspr.Doctor" class="com.github.eladrimonos.jasprintellij.actions.JasprDoctorAction"
                    description="Run 'jaspr doctor'" text="Jaspr Doctor"/>
            <action id="Jaspr.Clean" class="com.github.eladrimonos.jasprintellij.actions.JasprCleanAction"
                    text="Jaspr Clean" description="Run 'jaspr clean'"/>
            <separator/>
            <action id="Jaspr.DaemonStatus" class="com.github.eladrimonos.jasprintellij.actions.JasprDaemonStatusAction"
                    text="Check Daemon Status" description="Show the current status of the Jaspr Tooling Daemon"/>
            <action id="Jaspr.UpdateCli" class="com.github.eladrimonos.jasprintellij.actions.JasprUpdateCliAction"
                    text="Update Jaspr CLI" description="Run 'dart pub global activate jaspr_cli'"/>
        </group>

        <action
                id="New.JasprFile"
                class="com.github.eladrimonos.jasprintellij.template.file.NewJasprFileAction">
            <add-to-group
                    group-id="NewGroup"
                    anchor="after"
                    relative-to-action="Dart.NewDartFile"/>
        </action>

        <action
                id="Jaspr.ConvertHtmlToJaspr"
                class="com.github.eladrimonos.jasprintellij.actions.ConvertHtmlToJasprAction"
                text="Convert to Jaspr"
                description="Convert this HTML file to Jaspr Dart code using the tooling daemon"
                icon="com.github.eladrimonos.jasprintellij.icons.JasprIcons.JasprLogo">
            <add-to-group group-id="ProjectViewPopupMenu" relative-to-action="WeighingNewGroup" anchor="after"/>
        </action>
    </actions>
</idea-plugin>